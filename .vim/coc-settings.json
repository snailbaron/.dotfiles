{
    "html.autoClosingTags": false,
    "html.autoCreateQuotes": false,
    "html.format.extraLiners": "",
    "html.format.indentInnerHtml": true,
    "inlayHint.enable": false,
    "languageserver": {
        "clangd": {
            "command": "clangd",
            "filetypes": [
                "c",
                "cpp"
            ]
        },
        "cmake": {
            "command": "cmake-language-server",
            "filetypes": [
                "cmake"
            ],
            "initializationOptions": {
                "buildDirectory": "build"
            },
            "rootPatterns": [
                "build/"
            ]
        },
        "cucumber-language-server": {
            "filetypes": [
                "cucumber"
            ],
            "command": "cucumber-language-server",
            "args": [
                "--stdio"
            ]
        },
        "dart": {
            "filetypes": [
                "dart"
            ],
            "command": "dart",
            "args": [
                "language-server"
            ]
        },
        "efm": {
            "command": "efm-langserver",
            "filetypes": [
                "bzl"
            ]
        },
        "golangci-lint-langserver": {
            "filetypes": [
                "go"
            ],
            "command": "golangci-lint-langserver",
            "initializationOptions": {
                "command": [
                    "golangci-lint",
                    "run",
                    "--output.json.path",
                    "stdout",
                    "--show-stats=false",
                    "--issues-exit-code=1"
                ]
            }
        },
        "gopls": {
            "filetypes": [
                "go"
            ],
            "command": "gopls",
            "args": [
                "serve"
            ]
        },
        "just-lsp": {
            "filetypes": [
                "just"
            ],
            "command": "just-lsp"
        },
        "pyright": {
            "filetypes": [
                "python"
            ],
            "command": "pyright-langserver",
            "args": [
                "--stdio"
            ]
        },
        "ruff": {
            "filetypes": [
                "python"
            ],
            "command": "ruff",
            "args": [
                "server"
            ]
        },
        "starpls": {
            "args": [
                "server",
                "--experimental_enable_label_completions",
                "--experimental_infer_ctx_attributes",
                "--experimental_use_code_flow_analysis"
            ],
            "command": "starpls",
            "filetypes": [
                "bzl"
            ]
        }
    },
    "nix.enableLanguageServer": true,
    "nix.serverPath": "nil",
    "nix.serverSettings": {
        "nil": {
            "diagnostics": {
                "ignored": [
                    "unused_binding",
                    "unused_with"
                ]
            },
            "formatting": {
                "command": [
                    "nixfmt"
                ]
            }
        }
    },
    "python.formatting.provider": "ruff",
    "suggest.noselect": true,
    "yaml.format.enable": true
}
